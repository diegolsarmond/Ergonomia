# ──────────────────────────────────────────────────
# PostgreSQL — banco de dados externo
# ──────────────────────────────────────────────────
DB_HOST=easypanel.quantumtecnologia.com.br
DB_PORT=5435
DB_NAME=ergominas
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false
DB_MAX_CONNECTIONS=100

# ──────────────────────────────────────────────────
# Autenticação JWT (backend)
# Gere um valor aleatório forte para produção:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-in-production

# ──────────────────────────────────────────────────
# Servidor Express (backend)
# ──────────────────────────────────────────────────
PORT=3001

# ──────────────────────────────────────────────────
# Nginx (frontend) — URL interna do serviço backend
# No EasyPanel use o nome do serviço backend, ex: http://backend:3001
# ──────────────────────────────────────────────────
BACKEND_URL=http://backend:3001
# Atenção: sem barra final e sem /api/ — o nginx repassa o URI original completo

# ──────────────────────────────────────────────────
# Gemini AI (opcional)
# ──────────────────────────────────────────────────
GEMINI_API_KEY=
