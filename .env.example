# ──────────────────────────────────────────────────
# PostgreSQL — banco de dados externo
# ──────────────────────────────────────────────────
DB_HOST=easypanel.quantumtecnologia.com.br
DB_PORT=5435
DB_NAME=ergominas
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false
DB_MAX_CONNECTIONS=100

# ──────────────────────────────────────────────────
# Autenticação JWT (backend)
# Gere um valor aleatório forte para produção:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-in-production

# ──────────────────────────────────────────────────
# Servidor Express (backend)
# ──────────────────────────────────────────────────
PORT=3001
APP_URL=https://ergonomia.quantumtecnologia.com.br

# ──────────────────────────────────────────────────
# E-mail SMTP — para recuperação de senha
# Exemplos de provedores:
#   Gmail:    host=smtp.gmail.com  port=587  secure=false
#   Outlook:  host=smtp.office365.com  port=587  secure=false
#   SendGrid: host=smtp.sendgrid.net  port=587  secure=false
# ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=seu-email@gmail.com

# ──────────────────────────────────────────────────
# Gemini AI (opcional)
# ──────────────────────────────────────────────────
GEMINI_API_KEY=
